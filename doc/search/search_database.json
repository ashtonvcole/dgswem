irst convention under-the-hood. Arguments Type Intent Optional Attributes Name integer(kind=c_int), value :: np Number of nodes in the mesh. integer(kind=c_int), value :: nedges Number of edges in the mesh. integer(kind=c_int) :: nedno1 (nedges) List of starting node indexes for each edge. integer(kind=c_int) :: nedno2 (nedges) List of terminal node indexes for each edge.","tags":"","url":"module/c_interface.html"},{"title":"DG – DGSWEM Documentation","text":"Uses SIZES Variables Type Visibility Attributes Name Initial integer, public, TARGET :: rainfall integer, public, TARGET :: DGFLAG integer, public, TARGET :: DGHOT integer, public, TARGET :: DGHOTSPOOL integer, public :: DOF integer, public :: dofh integer, public :: dofl integer, public :: dofx integer, public :: EL integer, public, TARGET :: MNES integer, public, TARGET :: artdif integer, public, TARGET :: tune_by_hand integer, public :: IRK integer, public :: J1 integer, public :: J2 integer, public :: J3 integer, public :: negp_fixed integer, public :: nagp_fixed integer, public :: NAGP (8) integer, public :: NCHECK (8) integer, public :: NEGP (8) integer, public :: NEDGES integer, public :: NRK integer, public :: NIEDS integer, public :: NLEDS integer, public :: NEEDS integer, public :: NFEDS integer, public :: NREDS integer, public :: NEBEDS integer, public :: NIBEDS integer, public :: NIBSEG integer, public :: NEBSEG integer, public :: MNED integer, public :: MNLED integer, public :: MNSED integer, public :: MNRAED integer, public :: MNRIED integer, public, TARGET :: MODAL_IC integer, public :: P_READ integer, public :: P_READ2 integer, public, TARGET :: SLOPEFLAG integer, public :: test_el integer, public, TARGET :: FLUXTYPE integer, public, TARGET :: RK_STAGE integer, public, TARGET :: RK_ORDER integer, public, TARGET :: padapt integer, public, TARGET :: pflag integer, public, TARGET :: pl integer, public, TARGET :: ph integer, public, TARGET :: px integer, public, TARGET :: lebesgueP integer, public, 